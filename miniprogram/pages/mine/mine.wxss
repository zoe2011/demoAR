.container { background: var(--color-bg); min-height: 100vh; }
.profile-card { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 60rpx; background: var(--color-bg-card); }
.nickname { font-size: 36rpx; font-weight: 600; margin-top: 20rpx; }
.login-btn { margin-top: 20rpx; background: var(--color-primary); color: #000; border: none; font-size: 28rpx; }
.menu-list { margin-top: 40rpx; }
.menu-item { display: flex; align-items: center; padding: 28rpx 32rpx; background: var(--color-bg-card); border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-arrow { font-size: 36rpx; color: var(--color-text-secondary); }
