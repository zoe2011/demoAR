<!-- 个人中心 -->
<view class="container">
  <view class="profile-card">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <text class="nickname">{{nickname || '未登录'}}</text>
    <button class="login-btn" wx:if="{{!nickname}}" bindtap="onLogin">微信登录</button>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onNavToHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">导航历史</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onNavToFavorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">收藏地点</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于 DemoAR</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
