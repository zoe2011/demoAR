.container { background: var(--color-bg); min-height: 100vh; }
.header { padding: 32rpx; }
.title { font-size: 40rpx; font-weight: 700; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 32rpx; margin-top: 24rpx; color: var(--color-text-secondary); }
.empty-hint { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 12rpx; }
.list { padding: 0 24rpx; }
.record-item { background: var(--color-bg-card); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.record-route { display: flex; align-items: center; gap: 12rpx; }
.record-from, .record-to { font-size: 28rpx; }
.record-arrow { color: var(--color-primary); }
.record-meta { display: flex; gap: 24rpx; margin-top: 12rpx; font-size: 24rpx; color: var(--color-text-secondary); }
