.ar-container { position: relative; width: 100vw; height: 100vh; overflow: hidden; }

.ar-camera { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }

.ar-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }

.hud-actions {
  position: absolute; bottom: 60rpx; left: 0; right: 0;
  display: flex; justify-content: center; gap: 24rpx;
}

.btn-exit, .btn-map {
  padding: 16rpx 36rpx; border-radius: 40rpx; font-size: 26rpx; border: none;
}

.btn-exit { background: rgba(255, 71, 87, 0.2); color: var(--color-danger); }

.btn-map { background: rgba(255, 255, 255, 0.15); color: var(--color-text); }
