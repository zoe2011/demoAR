.ar-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.ar-camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.ar-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hud-top {
  position: absolute;
  top: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.hud-direction {
  background: rgba(0, 0, 0, 0.6);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(10rpx);
}

.direction-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.hud-distance {
  background: rgba(0, 0, 0, 0.6);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(10rpx);
}

.distance-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.distance-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 4rpx;
}

.hud-bottom {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.instruction-text {
  background: rgba(0, 212, 170, 0.15);
  color: var(--color-primary);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid rgba(0, 212, 170, 0.3);
}

.hud-actions {
  display: flex;
  gap: 24rpx;
}

.btn-exit, .btn-map {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: none;
}

.btn-exit {
  background: rgba(255, 71, 87, 0.2);
  color: var(--color-danger);
}

.btn-map {
  background: rgba(255, 255, 255, 0.15);
  color: var(--color-text);
}
