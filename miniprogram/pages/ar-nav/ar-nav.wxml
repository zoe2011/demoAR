<!-- AR 导航页面：Camera + Canvas 叠加 -->
<view class="ar-container">
  <!-- 摄像头 -->
  <camera 
    id="arCamera"
    device-position="back" 
    flash="off" 
    frame-size="large"
    binderror="onCameraError"
    class="ar-camera"
  />

  <!-- AR 叠加 Canvas -->
  <canvas 
    type="2d" 
    id="arCanvas" 
    class="ar-canvas"
    disable-scroll="{{true}}"
  />

  <!-- HUD 信息层（顶部） -->
  <view class="hud-top">
    <view class="hud-direction">
      <text class="direction-text">{{currentDirection}}</text>
    </view>
    <view class="hud-distance">
      <text class="distance-value">{{remainDistance}}</text>
      <text class="distance-unit">m</text>
    </view>
  </view>

  <!-- 指令栏（底部） -->
  <view class="hud-bottom safe-area-bottom">
    <view class="instruction-text">{{currentInstruction}}</view>
    <view class="hud-actions">
      <button class="btn-exit" bindtap="onExitAR">退出AR</button>
      <button class="btn-map" bindtap="onSwitchToMap">切换地图</button>
    </view>
  </view>
</view>
