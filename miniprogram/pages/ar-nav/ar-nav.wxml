<!-- AR 导航页面：Camera + Canvas 叠加 -->
<view class="ar-container">
  <!-- 摄像头 -->
  <camera 
    id="arCamera"
    device-position="back" 
    flash="off" 
    frame-size="large"
    binderror="onCameraError"
    class="ar-camera"
  />

  <!-- AR 叠加 Canvas -->
  <canvas 
    type="2d" 
    id="arCanvas" 
    class="ar-canvas"
    disable-scroll="{{true}}"
  />

  <!-- HUD 信息层 -->
  <navigation-hud 
    direction="{{currentDirection}}"
    remainDistance="{{remainDistance}}"
    instruction="{{currentInstruction}}"
  />

  <!-- 语音控制 -->
  <voice-guide muted="{{voiceMuted}}" bind:toggle="onVoiceToggle" />

  <!-- 底部按钮 -->
  <view class="hud-actions safe-area-bottom">
    <button class="btn-exit" bindtap="onExitAR">退出AR</button>
    <button class="btn-map" bindtap="onSwitchToMap">切换地图</button>
  </view>
</view>
