.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.search-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}

.map {
  flex: 1;
  width: 100%;
  height: 100%;
}

.bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(transparent, var(--color-bg-card) 30%);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.route-info {
  display: flex;
  gap: 24rpx;
}

.route-distance {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.route-duration {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  align-self: flex-end;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.btn {
  padding: 16rpx 32rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
}

.btn-outline {
  background: rgba(255, 255, 255, 0.1);
  color: var(--color-text);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.btn-primary {
  background: var(--color-primary);
  color: #000;
  font-weight: 600;
}

.btn-primary[disabled] {
  opacity: 0.4;
}
